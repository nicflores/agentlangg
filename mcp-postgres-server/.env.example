# Copy to .env and adjust as needed.

APP_LOG_LEVEL=INFO

# Database provider: "fake" uses an in-memory dict, "real" connects to Postgres.
DB_PROVIDER=fake

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mcp_user
POSTGRES_PASSWORD=mcp_password
POSTGRES_DB=mcp_db

# MCP server bind address (streamable-HTTP transport).
MCP_HOST=127.0.0.1
MCP_PORT=8000

# run_sql escape hatch guards.
RUN_SQL_DEFAULT_LIMIT=100
RUN_SQL_MAX_ROWS=1000
RUN_SQL_STATEMENT_TIMEOUT_MS=5000
